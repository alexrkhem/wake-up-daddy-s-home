# Copy this file to .env and fill in your values

# Anthropic API Key (for Jarvis AI)
ANTHROPIC_API_KEY=sk-ant-...

# ngrok auth token (for phone tunneling - get free at ngrok.com)
NGROK_AUTH_TOKEN=your-ngrok-token

# Google Calendar (optional - if you have credentials.json this auto-populates)
GOOGLE_CALENDAR_ENABLED=true
